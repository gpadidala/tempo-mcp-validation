# Copy to .env (never commit .env). The harness reads these.

# Tempo MCP endpoint (streamable HTTP).
TEMPO_MCP_URL=http://localhost:3200/api/mcp
# Direct Tempo HTTP API base, for parity assertions.
TEMPO_API_URL=http://localhost:3200
# OTLP HTTP ingest endpoint for the seed generator.
OTLP_HTTP_URL=http://localhost:4318

# Multi-tenancy: every request carries X-Scope-OrgID. tenant-a is the seeded,
# "primary" tenant; tenant-b exists only to prove isolation.
TENANT_PRIMARY=tenant-a
TENANT_SECONDARY=tenant-b
